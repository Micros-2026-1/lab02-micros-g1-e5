#include <xc.h>

#define _XTAL_FREQ 16000000   // Cristal de 8 MHz

void main(void)
{
    // Deshabilitar entradas analógicas
    ANSELA = 0x00;
    ANSELB = 0x00;
    ANSELC = 0x00;
    ANSELD = 0x00;
    ANSELE = 0x00;

    // RB0 como salida
    TRISBbits.TRISB0 = 0;
    LATBbits.LATB0 = 0;

    while(1)
    {
        LATBbits.LATB0 = 1;
        __delay_ms(1);   // 1 ms alto

        LATBbits.LATB0 = 0;
        __delay_ms(1);   // 1 ms bajo
    }
}