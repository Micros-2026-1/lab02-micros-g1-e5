// CONFIG1H
#pragma config FOSC = INTIO67   // Internal oscillator, RA6 and RA7 as I/O pins
#pragma config PLLCFG = OFF     // PLL x4 disabled
#pragma config PRICLKEN = ON    // Primary clock enabled
#pragma config FCMEN = OFF      // Fail-Safe Clock Monitor disabled
#pragma config IESO = OFF       // Internal/External Oscillator Switch Over disabled

// CONFIG2L
#pragma config PWRTEN = OFF     // Power-up Timer disabled
#pragma config BOREN = SBORDIS  // Brown-out reset enabled in hardware, disabled in software
#pragma config BORV = 190       // Brown-out voltage set to 1.90V

// CONFIG2H
#pragma config WDTEN = OFF      // Watchdog Timer disabled
#pragma config WDTPS = 32768    // Watchdog Timer postscale (not used if WDT disabled)

// CONFIG3H
#pragma config CCP2MX = PORTC1  // CCP2 function on RC1
#pragma config PBADEN = OFF     // PORTB<5:0> pins are digital on Reset
#pragma config CCP3MX = PORTB5  // CCP3 function on RB5
#pragma config HFOFST = ON      // HFINTOSC is stable immediately
#pragma config T3CMX = PORTC0   // T3CKI on RC0
#pragma config P2BMX = PORTC0   // CCP2B on RC0
#pragma config MCLRE = EXTMCLR  // MCLR pin enabled, RE3 input disabled

// CONFIG4L
#pragma config STVREN = ON      // Stack overflow/underflow will cause a Reset
#pragma config LVP = OFF        // Low-Voltage Programming disabled
#pragma config XINST = OFF      // Extended Instruction Set disabled
#pragma config DEBUG = OFF      // Background debugger disabled

// CONFIG5L/5H, 6L/6H, 7L/7H
#pragma config CP0 = OFF, CP1 = OFF, CP2 = OFF, CP3 = OFF   // Code protection disabled
#pragma config CPB = OFF, CPD = OFF                        // Boot and Data EEPROM protection disabled
#pragma config WRT0 = OFF, WRT1 = OFF, WRT2 = OFF, WRT3 = OFF // Write protection disabled
#pragma config WRTC = OFF, WRTB = OFF, WRTD = OFF
#pragma config EBTR0 = OFF, EBTR1 = OFF, EBTR2 = OFF, EBTR3 = OFF // Table read protection disabled
#pragma config EBTRB = OFF

#include <xc.h>
#define _XTAL_FREQ 16000000 

void main(void)
{
    OSCCONbits.IRCF = 0b111;
    OSCCONbits.SCS = 0b10;

    TRISBbits.TRISB0 = 0;
    LATBbits.LATB0 = 0;

    while(1)
    {
        LATBbits.LATB0 = 1;
        __delay_ms(1);

        LATBbits.LATB0 = 0;
        __delay_ms(1);
    }
}
